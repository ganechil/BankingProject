							"'silver',\n",
							"NULL,\n",
							"NULL,\n",
							"NULL,\n",
							"'gold',\n",
							"NULL,\n",
							"NULL,\n",
							"'gold',\n",
							"TRUE,\n",
							"3,\n",
							"current_timestamp()\n",
							"),\n",
							"\n",
							"(\n",
							"10,\n",
							"'daily_bank_kpi',\n",
							"'silver',\n",
							"NULL,\n",
							"NULL,\n",
							"NULL,\n",
							"'gold',\n",
							"NULL,\n",
							"NULL,\n",
							"'gold',\n",
							"TRUE,\n",
							"4,\n",
							"current_timestamp()\n",
							");\n",
							"\n",
							"-- COMMAND ----------\n",
							"\n",
							"INSERT INTO banking_metadata_tables\n",
							"VALUES (\n",
							"    11,\n",
							"    'risk_customer_summary',\n",
							"    'silver',\n",
							"    NULL,\n",
